#!/usr/bin/env -S uv run --script
#
# /// script
# requires-python = ">=3.10"
# dependencies = [
#     "pillow>=12.1.0",
#     "pillow-heif>=1.3.0",
#     "tqdm>=4.66.0",
#     "colorama>=0.4.6",
# ]
# ///

# Generated by Kimi-K2.5

"""
媒体文件完整性验证工具
支持图片：HEIC, JPG/JPEG
支持视频：MOV, MP4
"""

import argparse
import os
import subprocess
import sys
from concurrent.futures import ThreadPoolExecutor, as_completed
from pathlib import Path
from typing import Optional, Tuple

from colorama import Fore, Style, init
from PIL import Image
from pillow_heif import register_heif_opener
from tqdm import tqdm

# 注册 HEIC 支持
register_heif_opener()

# 支持的文件扩展名
IMAGE_EXTENSIONS = {".heic", ".jpg", ".jpeg"}
VIDEO_EXTENSIONS = {".mov", ".mp4"}
ALL_EXTENSIONS = IMAGE_EXTENSIONS | VIDEO_EXTENSIONS

# 初始化 colorama
init(autoreset=True)


def validate_image(file_path: Path) -> Tuple[bool, Optional[str]]:
    """
    验证图片完整性
    返回：(是否成功，错误信息)
    """
    try:
        with Image.open(file_path) as img:
            # 尝试加载所有数据
            img.load()
            # # 对于多帧图像（如 GIF），验证所有帧
            # n_frames = getattr(img, "n_frames", 0)
            # for frame in range(n_frames):
            #     img.seek(frame)
            #     img.load()
        return True, None
    except Exception as e:
        return False, str(e)


def validate_video(file_path: Path) -> Tuple[bool, Optional[str]]:
    """
    验证视频完整性 - 使用 ffmpeg 完整解码所有帧
    返回：(是否成功，错误信息)
    """
    try:
        # 使用 ffmpeg 完整解码验证
        # -v error: 只显示错误信息
        # -i input: 输入文件
        # -f null -: 输出到 null（不保存）
        # -threads 1: 单线程解码（避免占用过多资源）
        cmd = [
            "ffmpeg",
            "-v",
            "error",
            "-err_detect",
            "explode",
            "-i",
            str(file_path),
            "-f",
            "null",
            "-threads",
            "1",
            "-",
        ]

        result = subprocess.run(
            cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True
        )

        if result.returncode != 0:
            error_msg = (
                result.stderr.strip()
                if result.stderr
                else f"Exit code: {result.returncode}"
            )
            return False, error_msg

        return True, None
    except FileNotFoundError:
        return False, "ffmpeg not found. Please install ffmpeg."
    except Exception as e:
        return False, str(e)


def validate_file(file_path: Path) -> Tuple[Path, bool, Optional[str]]:
    """
    验证单个文件
    返回：(文件路径，是否成功，错误信息)
    """
    ext = file_path.suffix.lower()

    if ext in IMAGE_EXTENSIONS:
        success, error = validate_image(file_path)
    elif ext in VIDEO_EXTENSIONS:
        success, error = validate_video(file_path)
    else:
        return file_path, False, f"Unsupported file type: {ext}"

    return file_path, success, error


def scan_directory(directory: Path) -> list[Path]:
    """
    递归扫描目录，返回所有支持的媒体文件
    """
    files = []
    for ext in ALL_EXTENSIONS:
        files.extend(directory.rglob(f"*{ext}"))
        files.extend(directory.rglob(f"*{ext.upper()}"))
    return sorted(set(files))


def main():
    parser = argparse.ArgumentParser(
        description="验证媒体文件完整性（图片：HEIC/JPG，视频：MOV/MP4）",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
示例：
  %(prog)s /path/to/media
  %(prog)s /path/to/media --workers 8
        """,
    )
    parser.add_argument("directory", help="要扫描的目录路径")
    parser.add_argument(
        "--workers",
        "-w",
        type=int,
        default=os.cpu_count(),
        help=f"并行工作线程数（默认：{os.cpu_count()}，即 CPU 核心数）",
    )
    parser.add_argument(
        "--verbose", "-v", action="store_true", help="显示成功和失败的文件"
    )

    args = parser.parse_args()

    # 验证目录
    target_dir = Path(args.directory)
    if not target_dir.exists():
        print(f"{Fore.RED}错误：目录不存在：{target_dir}{Style.RESET_ALL}")
        sys.exit(1)
    if not target_dir.is_dir():
        print(f"{Fore.RED}错误：路径不是目录：{target_dir}{Style.RESET_ALL}")
        sys.exit(1)

    # 扫描文件
    print(f"{Fore.CYAN}正在扫描目录：{target_dir}{Style.RESET_ALL}")
    files = scan_directory(target_dir)

    if not files:
        print(f"{Fore.YELLOW}未找到支持的媒体文件{Style.RESET_ALL}")
        print(f"支持的格式：{', '.join(sorted(ALL_EXTENSIONS))}")
        sys.exit(0)

    print(
        f"{Fore.CYAN}找到 {len(files)} 个文件，使用 {args.workers} 个线程验证...{Style.RESET_ALL}"
    )
    print()

    # 统计
    total = len(files)
    success_count = 0
    fail_count = 0
    failed_files: list[Tuple[Path, str]] = []

    # 并行处理
    with ThreadPoolExecutor(max_workers=args.workers) as executor:
        future_to_file = {executor.submit(validate_file, f): f for f in files}

        with tqdm(total=total, desc="验证中", unit="file") as pbar:
            for future in as_completed(future_to_file):
                file_path, success, error = future.result()

                if success:
                    success_count += 1
                    if args.verbose:
                        print(f"{Fore.GREEN}[OK]{Style.RESET_ALL} {file_path}")
                else:
                    fail_count += 1
                    failed_files.append((file_path, error or "Unknown error"))
                    print(f"{Fore.RED}[FAIL]{Style.RESET_ALL} {file_path}")
                    print(f"      错误：{error}")

                pbar.update(1)

    # 输出统计
    print()
    print(f"{Fore.CYAN}{'=' * 60}{Style.RESET_ALL}")
    print(f"{Fore.CYAN}验证完成{Style.RESET_ALL}")
    print(f"{Fore.CYAN}{'=' * 60}{Style.RESET_ALL}")
    print(f"总计：{total} 个文件")
    print(f"{Fore.GREEN}成功：{success_count} 个{Style.RESET_ALL}")
    print(f"{Fore.RED}失败：{fail_count} 个{Style.RESET_ALL}")

    if failed_files:
        print()
        print(f"{Fore.RED}失败的文件列表:{Style.RESET_ALL}")
        for file_path, error in failed_files:
            print(f"  - {file_path}")
            print(f"    错误：{error}")
        sys.exit(1)
    else:
        print()
        print(f"{Fore.GREEN}所有文件验证通过！{Style.RESET_ALL}")
        sys.exit(0)


if __name__ == "__main__":
    main()
